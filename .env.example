# Shared database (used by api-server and lib/db)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maakon"

# Supabase public client keys (safe for frontend apps)
VITE_SUPABASE_URL="http://localhost:54321"
VITE_SUPABASE_ANON_KEY="replace-with-anon-key"
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-anon-key"

# Supabase server-only key (artifacts/api-server/.env only)
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"

# Environment
NODE_ENV="development"
LOG_LEVEL="info"

# API server (artifacts/api-server/.env)
# IMPORTANT: set PORT to 3001 for api-server when using `pnpm dev`.
PORT="3001"
CORS_ORIGINS="http://localhost:5173"
JSON_BODY_LIMIT="100kb"
URLENCODED_BODY_LIMIT="100kb"
# Optional hard host gate for admin API routes. Leave both blank to rely on admin role + MFA only.
ADMIN_SUBDOMAIN=""
ADMIN_ALLOWED_HOSTS=""
ADMIN_IP_WHITELIST=""
SLACK_WEBHOOK_URL=""
DEV_FIREBASE_BYPASS="false"

# Frontend (artifacts/maakon-web/.env)
# IMPORTANT: set PORT to 5173 in maakon-web/.env when using `pnpm dev`.
BASE_PATH="/"
API_URL="http://localhost:3001"
