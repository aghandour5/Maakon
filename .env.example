# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maakon"

# Supabase (Required for Authentication & Storage)
# Replace with your local Supabase or production values
VITE_SUPABASE_URL="http://localhost:54321"
VITE_SUPABASE_ANON_KEY="placeholder"
SUPABASE_SERVICE_ROLE_KEY="placeholder"
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="placeholder"

# Environment
NODE_ENV="development"

# API Server
PORT="3001"
# Admin Subdomain (Optional)
ADMIN_SUBDOMAIN="admin.maakon.com"
# Admin IP Whitelist (Optional, comma separated)
ADMIN_IP_WHITELIST=""
# Slack Webhook URL (Optional, for feedback)
SLACK_WEBHOOK_URL=""
# JWT Secret for MFA (Optional, dev default provided)
MFA_JWT_SECRET="default_dev_mfa_secret_do_not_use_in_prod_1234"
# Developer Firebase bypass (for testing auth)
DEV_FIREBASE_BYPASS="true"
# Log level
LOG_LEVEL="info"

# Frontend
# Base Path
BASE_PATH="/"
# API URL targeting the API Server
API_URL="http://localhost:3001"
