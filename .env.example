# ============================================================
# Maakon — Local Environment Variables Reference
# Copy the relevant section into the appropriate .env file.
# ============================================================

# artifacts/api-server/.env
PORT=3001
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/maakon
CORS_ORIGINS=http://localhost:5173
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_VERIFY_SERVICE_SID=<twilio-verify-service-sid>
# Development-only bypass flags. Keep unset in production.
DEV_FIREBASE_BYPASS=false
DEV_WHATSAPP_BYPASS=false

# artifacts/maakon-web/.env
PORT=5173
BASE_PATH=/
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>

# lib/db/.env  (used by drizzle-kit CLI)
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/maakon
